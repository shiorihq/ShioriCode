{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "SHIORICODE_LOG_WS_EVENTS",
    "SHIORICODE_MODE",
    "SHIORICODE_PORT",
    "SHIORICODE_NO_BROWSER",
    "SHIORICODE_HOME",
    "SHIORICODE_AUTH_TOKEN",
    "SHIORICODE_DESKTOP_WS_URL",
    "NUCLEO_LICENSE_KEY",
    "VITE_NUCLEO_LICENSE_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
